{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Verification Checklist",
  "description": "Post-deploy verification checks.",
  "type": "object",
  "required": ["checks"],
  "properties": {
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "expected_result"],
        "properties": {
          "id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["networking", "compute", "data", "security", "observability", "ci_cd"]
          },
          "expected_result": { "type": "string" },
          "evidence_required": { "type": "string" },
          "severity_if_failed": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          }
        }
      }
    }
  }
}
