{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cost Analysis",
  "description": "Structured cost analysis with estimated ranges. Heuristic model; not a billing guarantee.",
  "type": "object",
  "required": [
    "cost_summary",
    "estimated_monthly_cost_range",
    "assumptions",
    "confidence_score",
    "disclaimer"
  ],
  "properties": {
    "cost_summary": {
      "type": "object",
      "required": ["total_min", "total_max"],
      "properties": {
        "total_min": { "type": "number", "description": "Minimum estimated monthly cost (USD)" },
        "total_max": { "type": "number", "description": "Maximum estimated monthly cost (USD)" },
        "currency": { "type": "string", "default": "USD" }
      }
    },
    "estimated_monthly_cost_range": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "currency": { "type": "string", "default": "USD" }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Explicit usage assumptions"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "0–1; HIGH ≥0.8, MEDIUM 0.5–0.8, LOW <0.5"
    },
    "disclaimer": {
      "type": "string",
      "description": "Required disclaimer that estimates are not billing guarantees"
    },
    "missing_inputs": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Inputs that were inferred or defaulted"
    },
    "notes": {
      "type": "string",
      "description": "Additional context or caveats"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "cost_drivers"],
        "properties": {
          "component": { "type": "string" },
          "service_name": { "type": "string" },
          "option": { "type": "string" },
          "usage_assumptions": {
            "type": "array",
            "items": { "type": "string" }
          },
          "estimated_monthly_cost_min": { "type": "number" },
          "estimated_monthly_cost_max": { "type": "number" },
          "cost_min": { "type": "number" },
          "cost_max": { "type": "number" },
          "cost_drivers": {
            "type": "array",
            "items": { "type": "string" }
          },
          "savings_opportunities": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cost_classification": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "cheapest_viable_option": { "type": "string" },
          "optimized_option": { "type": "string" },
          "recommended_option": { "type": "string" },
          "service_options": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "savings_opportunities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "service_options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "component": { "type": "string" },
          "option": { "type": "string" },
          "cost_min": { "type": "number" },
          "cost_max": { "type": "number" }
        }
      }
    },
    "decision_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
