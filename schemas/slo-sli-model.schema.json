{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SLO/SLI Model",
  "description": "Availability, latency, error thresholds, monitoring signals. Required for every architecture.",
  "type": "object",
  "required": ["availability_target", "latency_expectations", "error_thresholds"],
  "properties": {
    "availability_target": {
      "type": "string",
      "description": "e.g. 99.9%, 99.5%"
    },
    "latency_expectations": {
      "type": "object",
      "properties": {
        "p50_ms": { "type": "number" },
        "p95_ms": { "type": "number" },
        "p99_ms": { "type": "number" }
      }
    },
    "error_thresholds": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "metric": { "type": "string" },
          "threshold": { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    },
    "monitoring_signals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Key metrics to monitor"
    }
  }
}
