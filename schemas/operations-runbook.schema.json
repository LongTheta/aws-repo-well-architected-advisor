{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Operations Runbook",
  "description": "Operational procedures for deployed services.",
  "type": "object",
  "required": ["service_name"],
  "properties": {
    "service_name": { "type": "string" },
    "alerts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "condition": { "type": "string" },
          "severity": { "type": "string" }
        }
      }
    },
    "dashboards": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "mode": { "type": "string" },
          "symptoms": { "type": "string" },
          "mitigation": { "type": "string" }
        }
      }
    },
    "rollback_steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "backup_restore_notes": { "type": "string" },
    "escalation_notes": { "type": "string" }
  }
}
