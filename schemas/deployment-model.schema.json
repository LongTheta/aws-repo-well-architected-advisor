{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deployment Model",
  "description": "Bootstrap order, apply phases, dependencies. Required for every architecture.",
  "type": "object",
  "required": ["bootstrap_order", "apply_phases", "dependencies"],
  "properties": {
    "bootstrap_order": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Order of initial provisioning (e.g. VPC, IAM, then compute)"
    },
    "apply_phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "apply_order"],
        "properties": {
          "name": { "type": "string" },
          "apply_order": { "type": "integer" },
          "resources": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "validation_gates": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    }
  }
}
