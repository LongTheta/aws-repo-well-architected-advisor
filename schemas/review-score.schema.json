{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Score",
  "description": "Schema for review output: weighted scores, findings, production readiness",
  "type": "object",
  "properties": {
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "score": { "type": "number", "minimum": 0, "maximum": 10 },
          "rationale": { "type": "string" },
          "evidence_found": { "type": "array", "items": { "type": "string" } },
          "missing_evidence": { "type": "array", "items": { "type": "string" } },
          "key_risks": { "type": "array", "items": { "type": "string" } },
          "recommended_actions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "weighted_overall_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "letter_grade": { "type": "string", "enum": ["A", "B+", "B", "C", "D", "F"] },
    "production_readiness": { "type": "string", "enum": ["READY", "CONDITIONAL", "NOT_READY"] },
    "confidence_level": { "type": "string", "enum": ["Confirmed", "Strongly Inferred", "Assumed"] },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "evidence_type": { "type": "string", "enum": ["observed", "inferred", "missing", "contradictory"] },
          "confidence": { "type": "string", "enum": ["Confirmed", "Strongly Inferred", "Assumed"] },
          "affected_area": { "type": "string" },
          "recommendation": { "type": "string" },
          "role_filter": { "type": "array", "items": { "type": "string", "enum": ["architect", "developer", "security", "operations"] } }
        }
      }
    },
    "evidence_found": { "type": "array", "items": { "type": "string" } },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "top_remediation_priorities": { "type": "array", "items": { "type": "string" } }
  }
}
