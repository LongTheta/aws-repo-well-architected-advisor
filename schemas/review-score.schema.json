{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Review Score",
  "description": "Schema for review output: weighted scores, findings, production readiness. Supports v2/v3 evidence model (confidence_score, source_reference, affected_standard, implementation_status).",
  "type": "object",
  "properties": {
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "score": { "type": "number", "minimum": 0, "maximum": 10 },
          "rationale": { "type": "string" },
          "evidence_found": { "type": "array", "items": { "type": "string" } },
          "missing_evidence": { "type": "array", "items": { "type": "string" } },
          "key_risks": { "type": "array", "items": { "type": "string" } },
          "recommended_actions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "weighted_overall_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "letter_grade": { "type": "string", "enum": ["A", "B+", "B", "C", "D", "F"] },
    "production_readiness": { "type": "string", "enum": ["READY", "CONDITIONAL", "NOT_READY"] },
    "confidence_level": { "type": "string", "enum": ["Confirmed", "Strongly Inferred", "Assumed"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "v3: 0.0–1.0 confidence" },
    "nist_alignment": { "type": "string", "enum": ["STRONG", "PARTIAL", "WEAK"], "description": "Federal overlay: evidence-based NIST alignment" },
    "dod_alignment": { "type": "string", "enum": ["STRONG", "PARTIAL", "WEAK"], "description": "Federal overlay: evidence-based DoD alignment" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "summary": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "evidence_type": { "type": "string", "enum": ["observed", "inferred", "missing", "contradictory", "unverifiable"] },
          "confidence": { "type": "string", "enum": ["Confirmed", "Strongly Inferred", "Assumed"] },
          "confidence_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "v3: 0.0–1.0" },
          "source_reference": { "type": "string", "description": "v3: file, path, pattern, or explicit absence" },
          "affected_standard": { "type": "string", "enum": ["AWS_WELL_ARCHITECTED", "NIST_800_53", "NIST_800_37", "NIST_800_190", "NIST_800_204A", "NIST_800_204B", "NIST_800_204C", "NIST_800_204D", "DOD_ZERO_TRUST", "DOD_DEVSECOPS"] },
          "affected_control_or_principle": { "type": "string", "description": "v3: control family, practice, or architecture principle" },
          "implementation_status": { "type": "string", "enum": ["implemented", "partially_implemented", "missing", "cannot_verify_from_repo"] },
          "affected_area": { "type": "string" },
          "recommendation": { "type": "string" },
          "role_filter": { "type": "array", "items": { "type": "string", "enum": ["architect", "developer", "security", "operations"] } }
        }
      }
    },
    "evidence_found": { "type": "array", "items": { "type": "string" } },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "top_remediation_priorities": { "type": "array", "items": { "type": "string" } },
    "control_alignment_summary": {
      "type": "object",
      "description": "v3 federal: implemented, partially_implemented, missing, unverifiable",
      "properties": {
        "implemented": { "type": "array", "items": { "type": "string" } },
        "partially_implemented": { "type": "array", "items": { "type": "string" } },
        "missing": { "type": "array", "items": { "type": "string" } },
        "unverifiable": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decision_log": { "type": "array", "items": { "type": "object" } },
    "confidence_summary": {
      "type": "object",
      "properties": {
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "unverifiable_areas": { "type": "array", "items": { "type": "string" } },
        "inherited_control_dependencies": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
