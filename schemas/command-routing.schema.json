{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Command Routing",
  "description": "Schema for command-to-agent-to-skill routing",
  "type": "object",
  "properties": {
    "command": {
      "type": "string",
      "enum": [
        "quick-review",
        "repo-assess",
        "solution-discovery",
        "platform-design",
        "scaffold",
        "design-and-implement",
        "incremental-fix",
        "federal-checklist",
        "gitops-audit",
        "quality-gate",
        "doc-sync",
        "verify",
        "checkpoint",
        "orchestrate"
      ]
    },
    "agent": {
      "type": "string",
      "enum": [
        "solution-architect",
        "product-manager-discovery",
        "repo-auditor",
        "federal-security-reviewer",
        "gitops-reviewer",
        "cloud-platform-reviewer",
        "documentation-writer",
        "scaffold-implementer",
        "design-and-implement-conductor"
      ]
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" }
    },
    "output_schema": {
      "type": "string",
      "enum": ["review-score", "solution-brief", "target-architecture", "incremental-fix", "verification", null]
    },
    "blocking": {
      "type": "string",
      "enum": ["none", "missing_evidence", "quality_gate", "evidence_tags"]
    }
  },
  "required": ["command", "agent"]
}
